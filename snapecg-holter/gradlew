#!/bin/sh
# Gradle wrapper stub — downloads and runs the pinned Gradle.
# Do NOT fall through to a system `gradle` on PATH: AGP 8.2 only
# accepts Gradle 8.x, but Ubuntu / GitHub-hosted runners ship a much
# newer Gradle (9.x) which silently breaks the build. Always use the
# version captured below.

GRADLE_VERSION=8.5
GRADLE_DIST_URL="https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip"
GRADLE_HOME="${HOME}/.gradle/wrapper/dists/gradle-${GRADLE_VERSION}-bin"

if [ ! -d "$GRADLE_HOME" ]; then
    echo "Downloading Gradle ${GRADLE_VERSION}..."
    mkdir -p "$GRADLE_HOME"
    curl -sL "$GRADLE_DIST_URL" -o /tmp/gradle.zip
    unzip -q /tmp/gradle.zip -d "$GRADLE_HOME"
    rm /tmp/gradle.zip
fi

exec "$GRADLE_HOME/gradle-${GRADLE_VERSION}/bin/gradle" "$@"

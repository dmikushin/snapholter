# Copy this file to app/keystore.properties and fill in real values.
# app/keystore.properties is gitignored.
#
# To generate a release keystore:
#   keytool -genkey -v -keystore release.keystore -alias snapecg \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Then point storeFile at the generated .keystore. Path is resolved
# relative to the repository root (rootProject).

storeFile=release.keystore
storePassword=changeme
keyAlias=snapecg
keyPassword=changeme

[Unit]
Description=SnapECG Holter Connector
Documentation=https://github.com/dmikushin/snapecg-b10
After=network-online.target bluetooth.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/forge/snapholter/snapecg-connector/connector.py
WorkingDirectory=%h/forge/snapholter/snapecg-connector
Restart=on-failure
RestartSec=5
Environment=PYTHONPATH=%h/forge/snapholter/src

[Install]
WantedBy=default.target
